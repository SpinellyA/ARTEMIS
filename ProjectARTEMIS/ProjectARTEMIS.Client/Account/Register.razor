@page "/register"
@layout BlankLayout
@attribute [AllowAnonymous]
@inject HttpClient Http
@inject NavigationManager Nav

<MudGrid Justify="Justify.Center" Style="min-height: 100vh; align-items: center;">
    <MudItem xs="12" sm="8" md="5">
        <MudPaper Elevation="4" Style="border-radius: 16px; overflow: hidden;">
            <MudGrid Spacing="0">

                <MudItem xs="12" md="5" Style="background: #3C3489; padding: 2rem;">
                    <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Style="font-size: 48px; color: #AFA9EC;" />
                    <MudText Typo="Typo.h6" Style="color: #CECBF6; margin-top: 1rem;">Project Artemis</MudText>
                    <MudText Typo="Typo.body2" Style="color: #AFA9EC;">
                        Create your account :)
                    </MudText>
                </MudItem>

                <MudItem xs="12" md="7" Style="padding: 2rem;">
                    <MudText Typo="Typo.h5" GutterBottom>Create account</MudText>
                    <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
                        Fill in your details to get started.
                    </MudText>

                    @if (errorMessage is not null)
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-3">@errorMessage</MudAlert>
                    }

                    <MudTextField @bind-Value="username"
                                  Label="Username"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Outlined.Person"
                                  Class="mb-3" />

                    <MudTextField @bind-Value="email"
                                  Label="Email"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Outlined.Email"
                                  Class="mb-3" />

                    <MudTextField @bind-Value="password"
                                  Label="Password"
                                  Variant="Variant.Outlined"
                                  InputType="@passwordInputType"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@passwordIcon"
                                  OnAdornmentClick="TogglePassword"
                                  Class="mb-3" />

                    <MudTextField @bind-Value="confirmPassword"
                                  Label="Confirm password"
                                  Variant="Variant.Outlined"
                                  InputType="@passwordInputType"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@passwordIcon"
                                  OnAdornmentClick="TogglePassword"
                                  Class="mb-4" />

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth
                               OnClick="HandleRegister"
                               Disabled="loading"
                               EndIcon="@Icons.Material.Filled.ArrowForward">
                        @(loading ? "Creating account…" : "Create account")
                    </MudButton>

                    <MudText Typo="Typo.caption" Class="mt-3 d-flex justify-center" Color="Color.Secondary">
                        Already have an account? <MudLink Href="/login" Class="ml-1">Sign in</MudLink>
                    </MudText>
                </MudItem>

            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    string username = "", email = "", password = "", confirmPassword = "";
    bool loading = false;
    bool showPassword = false;
    string? errorMessage;

    InputType passwordInputType => showPassword ? InputType.Text : InputType.Password;
    string passwordIcon => showPassword
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;

    void TogglePassword() => showPassword = !showPassword;

    async Task HandleRegister()
    {
        errorMessage = null;

        if (password != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        loading = true;

        var response = await Http.PostAsJsonAsync("/api/v1/auth/register", new
        {
            username,
            email,
            password
        });

        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/login?registered=true");
        }
        else
        {
            var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
            errorMessage = error?.Message ?? "Something went wrong.";
        }

        loading = false;
    }

    record ErrorResponse(string Message);
}